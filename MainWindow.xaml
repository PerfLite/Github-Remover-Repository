<Window
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:gif="http://wpfanimatedgif.codeplex.com"
        mc:Ignorable="d" x:Class="GitCleaner.MainWindow" Loaded="Window_Loaded"
        Title="GitHub Repo Cleaner"
        Height="500" Width="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">

    <Border Background="#0A0E14" CornerRadius="12" BorderBrush="Transparent" BorderThickness="1">
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="35"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#0A0E14" CornerRadius="8,8,0,0" 
                    MouseLeftButtonDown="DragWindow">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Image x:Name="IconImage" Grid.Column="0" Width="24" Height="24" Margin="10,0,5,0"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="Git" FontSize="14" FontWeight="Bold" Foreground="White"/>
                        <TextBlock x:Name="TitleText" Text="Cleaner" FontSize="14" FontWeight="Bold" Foreground="White"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button x:Name="LangBtn" Width="30" Height="30" 
                                Background="Transparent" Foreground="White" 
                                BorderThickness="0" Click="LangBtn_Click" 
                                Margin="0,0,5,0">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" 
                                            BorderBrush="Transparent" BorderThickness="2" CornerRadius="5">
                                        <TextBlock x:Name="LangText" Text="RU" FontSize="12" FontWeight="Bold"
                                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="BorderBrush" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="CloseBtn" Width="30" Height="30" 
                                Background="Transparent" Foreground="White" 
                                BorderThickness="0" Click="CloseBtn_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" 
                                            BorderBrush="Transparent" BorderThickness="2" CornerRadius="5">
                                        <Image x:Name="CloseIcon" Width="20" Height="20" 
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="BorderBrush" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Список репозиториев -->
            <ListBox x:Name="RepoList" Grid.Row="1" 
                     Background="Transparent" Foreground="#d8bafd" 
                     FontSize="15" BorderBrush="Transparent" 
                     BorderThickness="3" Margin="0,10"
                     MouseLeftButtonDown="RepoList_MouseDown" d:ItemsSource="{d:SampleData ItemCount=5}">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="8,5"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.Template>
                    <ControlTemplate TargetType="ListBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8">
                            <ScrollViewer VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Disabled">
                                <ItemsPresenter/>
                            </ScrollViewer>
                        </Border>
                    </ControlTemplate>
                </ListBox.Template>
            </ListBox>

            <!-- Кнопки -->
            <Grid Grid.Row="2" Margin="0,10,0,0">
                <Button x:Name="ClearBtn" Content="Отменить выбор" Width="123" Height="35" 
                        Background="#0a0e14" Foreground="White" BorderThickness="0" 
                        HorizontalAlignment="Left" Click="ClearBtn_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" 
                                    BorderBrush="Transparent" BorderThickness="2" CornerRadius="5">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="BorderBrush" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button x:Name="RefreshBtn" Width="100" Height="35" Margin="0,0,10,0" 
                        Background="#0a0e14" Foreground="White" BorderThickness="0" 
                        Click="RefreshBtn_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" 
                                    BorderBrush="Transparent" BorderThickness="2" CornerRadius="5">
                                <TextBlock x:Name="RefreshText" Text="🔄 Обновить" Foreground="{TemplateBinding Foreground}" 
                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="BorderBrush" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Button x:Name="DeleteBtn" Content="❌ Удалить" Width="100" Height="35" 
                        Background="#D32F2F" Foreground="White" BorderThickness="0" 
                        HorizontalAlignment="Right" Click="DeleteBtn_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}" 
                                    BorderBrush="Transparent" BorderThickness="2" CornerRadius="5">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="BorderBrush" Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Grid>
    </Border>
</Window>